{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Live observability for the FateForger timeboxing agent — stage progression, LLM I/O, token usage, and constraint memory",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Overview",
      "type": "row"
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "LLM Calls",
      "type": "stat",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(increase(fateforger_llm_calls_total[$__range]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "100 * sum(increase(fateforger_llm_calls_total{status=\"ok\"}[$__range])) / (sum(increase(fateforger_llm_calls_total[$__range])) + 1e-9)",
          "legendFormat": "%",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "LLM Errors",
      "type": "stat",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(increase(fateforger_llm_calls_total{status!=\"ok\"}[$__range]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Active Stage Labels",
      "type": "stat",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "count(count by (call_label) (fateforger_llm_calls_total))",
          "legendFormat": "Stage labels",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "🤖 LLM Call Activity",
      "type": "row"
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "xTickLabelRotation": -30,
        "xTickLabelSpacing": 150
      },
      "title": "LLM Calls by Stage / Label",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sort_desc(sum by (call_label) (increase(fateforger_llm_calls_total{model=~\"$model\"}[$__range])))",
          "legendFormat": "{{call_label}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "LLM Call Rate by Model",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum by (model) (rate(fateforger_llm_calls_total[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "LLM Error Rate by Type",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum by (status) (rate(fateforger_llm_calls_total{status!=\"ok\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "🔍 Session Explorer",
      "type": "row"
    },
    {
      "datasource": { "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "title": "Session Events  [ filter: session_key=$session_key  stage=$stage ]",
      "type": "logs",
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=~\"fateforger.*\", stage=~\"$stage\"} | json | session_key =~ \"$session_key\" | line_format \"[{{.event}}] stage={{.stage}} elapsed={{.elapsed_s}}s  {{.message}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 103,
      "title": "🧠 LLM Input / Output Inspector",
      "type": "row"
    },
    {
      "datasource": { "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 33 },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "title": "LLM I/O Log  [ model=$model  session=$session_key ]",
      "type": "logs",
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=\"fateforger_llm_io\", model=~\"$model\"} |~ \"$session_key\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "prompt_tokens" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "completion_tokens" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          },
          {
            "matcher": { "id": "byName", "options": "elapsed_s" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "stage" },
            "properties": [{ "id": "custom.width", "value": 160 }]
          },
          {
            "matcher": { "id": "byName", "options": "call_label" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 47 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": []
      },
      "title": "Token Usage per LLM Call  (response events, session=$session_key)",
      "type": "table",
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=\"fateforger_llm_io\", model=~\"$model\"} | json call_label, prompt_tokens, completion_tokens, session_key | session_key =~ \"$session_key\"",
          "queryType": "range",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "replace": false,
            "keepTime": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "tsNs": true, "id": true, "Line": true },
            "indexByName": {
              "Time": 0,
              "stage": 1,
              "call_label": 2,
              "model": 3,
              "prompt_tokens": 4,
              "completion_tokens": 5,
              "elapsed_s": 6,
              "session_key": 7
            },
            "renameByName": {
              "Time": "Timestamp",
              "call_label": "Call Label",
              "prompt_tokens": "Prompt Tokens",
              "completion_tokens": "Completion Tokens",
              "elapsed_s": "Elapsed (s)"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "id": 104,
      "title": "🔒 Stage Detail & Constraint Memory",
      "type": "row"
    },
    {
      "datasource": { "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 58 },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "title": "Stage Transitions (graph_turn_start / graph_turn_end)",
      "type": "logs",
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=~\"fateforger.*\", stage=~\"$stage\"} | json | event=~\"graph_turn_start|graph_turn_end\" | session_key =~ \"$session_key\" | line_format \"[{{.event}}] stage={{.node_name}} elapsed={{.elapsed_s}}s\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 58 },
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "title": "Constraint Memory Snapshots",
      "type": "logs",
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=~\"fateforger.*\"} | json | session_key =~ \"$session_key\" | event = \"constraints_active_snapshot\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Seconds",
            "axisPlacement": "auto",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 2,
            "axisSoftMin": 0,
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "showPoints": "always",
            "pointSize": 6,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 68 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Stage Elapsed Time (graph_turn_end elapsed_s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=~\"fateforger.*\", stage=~\"$stage\"} | json | event = \"graph_turn_end\" | session_key =~ \"$session_key\" | unwrap elapsed_s | __error__=\"\"",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["fateforger", "timeboxing", "llm", "agents"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": ".*", "value": ".*" },
        "description": "Filter by session key (regex). Leave as .* for all sessions. Paste from Slack thread_ts or logs.",
        "hide": 0,
        "label": "Session Key (regex)",
        "name": "session_key",
        "options": [],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "uid": "loki" },
        "definition": "label_values({job=\"fateforger_llm_io\"}, model)",
        "description": "LLM model in use",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Model",
        "multi": true,
        "name": "model",
        "options": [],
        "query": "label_values({job=\"fateforger_llm_io\"}, model)",
        "refresh": 2,
        "sort": 0,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "description": "Timeboxing pipeline stage",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Stage",
        "multi": true,
        "name": "stage",
        "options": [
          { "selected": false, "text": "CollectConstraints", "value": "CollectConstraints" },
          { "selected": false, "text": "CaptureInputs", "value": "CaptureInputs" },
          { "selected": false, "text": "Skeleton", "value": "Skeleton" },
          { "selected": false, "text": "Capture", "value": "Capture" },
          { "selected": false, "text": "Refine", "value": "Refine" },
          { "selected": false, "text": "ReviewCommit", "value": "ReviewCommit" },
          { "selected": false, "text": "TurnInitNode", "value": "TurnInitNode" },
          { "selected": false, "text": "DecisionNode", "value": "DecisionNode" }
        ],
        "query": "CollectConstraints,CaptureInputs,Skeleton,Capture,Refine,ReviewCommit,TurnInitNode,DecisionNode",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FateForger — Timeboxing Agent",
  "uid": "fateforger-timeboxing",
  "version": 1
}
