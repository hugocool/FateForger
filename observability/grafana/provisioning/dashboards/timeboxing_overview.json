{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Timeboxing observability overview: health, errors, latency, and token/call concentration.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "App Up",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "uid": "prometheus" }, "expr": "max(up{job=\"fateforger_app\"})" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "LLM Calls (range)",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"], "values": false, "fields": "" }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "datasource": { "uid": "prometheus" }, "expr": "sum(increase(fateforger_llm_calls_total[$__range]))" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tool Calls (range)",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"], "values": false, "fields": "" }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "uid": "prometheus" }, "expr": "sum(increase(fateforger_tool_calls_total[$__range]))" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errors (range)",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"], "values": false, "fields": "" }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "uid": "prometheus" }, "expr": "sum(increase(fateforger_errors_total[$__range]))" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Stage p95 Duration (seconds)",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(fateforger_stage_duration_seconds_bucket{stage=~\"$stage\"}[$__rate_interval])))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "LLM Call Rate by Call Label",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus" },
          "expr": "sum by (call_label) (rate(fateforger_llm_calls_total{call_label=~\"$call_label\"}[$__rate_interval]))",
          "legendFormat": "{{call_label}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "LLM Tokens by Call Label (range)",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus" },
          "expr": "sort_desc(sum by (call_label) (increase(fateforger_llm_tokens_total{call_label=~\"$call_label\"}[$__range])))",
          "legendFormat": "{{call_label}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Errors by Stage (rate)",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus" },
          "expr": "sum by (stage, error_type) (rate(fateforger_errors_total{stage=~\"$stage\"}[$__rate_interval]))",
          "legendFormat": "{{stage}}/{{error_type}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Loki Quick Triage (errors/timeout/slow)",
      "datasource": { "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "loki" },
          "expr": "{job=~\"fateforger_session|fateforger_llm_io|docker\"} |~ \"(?i)(error|timeout|graph_turn_slow|failed)\""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["fateforger", "timeboxing", "overview", "observability"],
  "templating": {
    "list": [
      {
        "name": "stage",
        "label": "Stage",
        "type": "query",
        "datasource": { "uid": "prometheus" },
        "query": "label_values(fateforger_stage_duration_seconds_sum, stage)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "call_label",
        "label": "Call Label",
        "type": "query",
        "datasource": { "uid": "prometheus" },
        "query": "label_values(fateforger_llm_calls_total, call_label)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "FateForger — Timeboxing Overview",
  "uid": "fateforger-timeboxing-overview",
  "version": 1
}
