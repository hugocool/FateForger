+class PatchContentDecoder(ABC):
+    """Decode TBPatch payloads from typed response content."""
+
+    @abstractmethod
+    def supports(self, content: Any) -> bool:
+        """Return whether this decoder handles the given content type."""
+
+    @abstractmethod
+    def decode(self, content: Any) -> TBPatch:
+        """Decode content into a validated ``TBPatch`` payload."""
+
+
+class TBPatchInstanceDecoder(PatchContentDecoder):
+    """Pass-through decoder for already typed patch objects."""
+
+    def supports(self, content: Any) -> bool:
+        return isinstance(content, TBPatch)
+
+    def decode(self, content: Any) -> TBPatch:
+        return content
+
+
+class TBPatchDictDecoder(PatchContentDecoder):
+    """Decoder for dict payloads returned by model adapters."""
+
+    def supports(self, content: Any) -> bool:
+        return isinstance(content, dict)
+
+    def decode(self, content: Any) -> TBPatch:
+        try:
+            return TBPatch.model_validate(content)
+        except Exception as exc:  # pragma: no cover - delegated by pydantic internals
+            raise ValueError(f"TBPatch validation failed from dict payload: {exc}") from exc
+
+
+class TBPatchJsonStringDecoder(PatchContentDecoder):
+    """Decoder for JSON string payloads with optional code fences."""
+
+    def supports(self, content: Any) -> bool:
+        return isinstance(content, str)
+
+    def decode(self, content: Any) -> TBPatch:
+        raw_text = _strip_markdown_fences(content.strip())
+        try:
+            return TBPatch.model_validate_json(raw_text)
+        except Exception as exc:  # pragma: no cover - delegated by pydantic internals
+            raise ValueError(f"TBPatch parse/validation failed: {exc}") from exc
+
+
+@dataclass(frozen=True)
+class PatchResponseDecoder:
+    """Composable decoder chain for extracting ``TBPatch`` results."""
+
+    decoders: tuple[PatchContentDecoder, ...] = (
+        TBPatchInstanceDecoder(),
+        TBPatchJsonStringDecoder(),
+        TBPatchDictDecoder(),
+    )
+
+    def decode_response(self, response: Any) -> TBPatch:
+        content = getattr(response.chat_message, "content", None)
+        for decoder in self.decoders:
+            if decoder.supports(content):
+                return decoder.decode(content)
+        raise ValueError(f"Could not extract TBPatch from response: {type(content).__name__}")
+
+
+@dataclass(frozen=True)
+class PatchRetryPolicy:
+    """Classify patch failures into retryable/non-retryable outcomes."""
+
+    non_retryable_error_types: frozenset[str] = frozenset(
+        {"AuthenticationError", "PermissionDeniedError", "BadRequestError"}
+    )
+    non_retryable_status_codes: frozenset[int] = frozenset({400, 401, 403, 404, 422})
+    retryable_status_codes: frozenset[int] = frozenset({408, 409, 425, 429})
+
+    def is_retryable(self, error: Exception) -> bool:
+        for item in _iter_exception_chain(error):
+            if type(item).__name__ in self.non_retryable_error_types:
+                return False
+            status = self._status_code(item)
+            if status is None:
+                continue
+            if status in self.non_retryable_status_codes:
+                return False
+            if status in self.retryable_status_codes or status >= 500:
+                return True
+        return True
+
+    @staticmethod
+    def _status_code(error: Exception) -> int | None:
+        for attr in ("status_code", "http_status", "status"):
+            value = getattr(error, attr, None)
+            if isinstance(value, int):
+                return value
+        response = getattr(error, "response", None)
+        value = getattr(response, "status_code", None)
+        if isinstance(value, int):
+            return value
+        return None
+
+
+@dataclass(frozen=True)
+class PatchErrorFeedbackBuilder:
+    """Build concise retry guidance from validator/apply exceptions."""
+
+    max_chars: int = 1200
+    max_detail_items: int = 6
+
+    def build(self, *, error: Exception) -> str:
+        head = str(error).strip() or type(error).__name__
+        details = self._extract_details(error)
+        lines: list[str] = [head]
+        if details:
+            lines.append("Violations:")
+            lines.extend(f"- {item}" for item in details)
+        return _truncate("\n".join(lines), max_chars=self.max_chars)
+
+    def _extract_details(self, error: Exception) -> list[str]:
+        details: list[str] = []
+        for item in _iter_exception_chain(error):
+            extractor = getattr(item, "errors", None)
+            if not callable(extractor):
+                continue
+            raw = extractor()
+            if not isinstance(raw, list):
+                continue
+            for detail in raw[: self.max_detail_items]:
+                if not isinstance(detail, dict):
+                    continue
+                loc = detail.get("loc")
+                loc_text = (
+                    ".".join(str(part) for part in loc)
+                    if isinstance(loc, (list, tuple)) and loc
+                    else "root"
+                )
+                detail_type = str(detail.get("type") or "validation_error")
+                message = str(detail.get("msg") or "").strip()
+                details.append(f"{detail_type} at {loc_text}: {message}".strip(": "))
+        return details
+
+
+_DEFAULT_PATCH_RESPONSE_DECODER = PatchResponseDecoder()
+_DEFAULT_PATCH_RETRY_POLICY = PatchRetryPolicy()
+_DEFAULT_PATCH_ERROR_FEEDBACK = PatchErrorFeedbackBuilder()
